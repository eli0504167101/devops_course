pipeline {
    agent any
    environment {
        DOCKER_IMAGE = 'docker.io/eli0504167101/python-clock-app'
    }
    stages {
        stage('Run Tests') {
            steps {
                echo 'Running python linter or tests...'
            }
        }
        stage('Build & Push Docker Image') {
            steps {
                dir('jenkins-app1') {
                    sh "docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} ."
                }
            }
        }
        stage('Update ArgoCD Manifests') {
            steps {
                dir('k8s-manifests-repo') {
                    script {
                        withCredentials([usernamePassword(credentialsId: 'github-creds', passwordVariable: 'GIT_PASSWORD', usernameVariable: 'GIT_USERNAME')]) {
                            sh '''
                            git config --local credential.helper store
                            echo "https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com" > ~/.git-credentials
                            
                            git fetch origin
                            git reset --hard origin/master
                            
                            sed -i "s|image: .*python-clock-app:.*|image: ${DOCKER_IMAGE}:${BUILD_NUMBER}|g" jenkins-app1/deployment.yaml
                            
                            git add jenkins-app1/deployment.yaml
                            git commit -m "Automated deployment: updated image tag to build ${BUILD_NUMBER} [skip ci]"
                            git push origin HEAD:master
                            
                            rm ~/.git-credentials
                            git config --local --unset credential.helper
                            '''
                        }
                    }
                }
            }
        }
    }
}
