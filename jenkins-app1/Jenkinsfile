pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "docker.io/eli0504167101/python-clock-app"
    }

    stages {
        stage('Checkout SCM') {
            steps {
                checkout scm
            }
        }

        stage('Run Tests') {
            steps {
                echo "Running python linter or tests..."
            }
        }

        stage('Build & Push Docker Image') {
            steps {
                script {
                    dir('jenkins-app1') {
                        sh "docker build -t ${DOCKER_IMAGE}:${env.BUILD_NUMBER} ."
                    }
                }
            }
        }

        stage('Update ArgoCD Manifests') {
            steps {
                dir('k8s-manifests-repo') {
                    script {
                        sh "sed -i 's|image: .*python-clock-app:.*|image: ${DOCKER_IMAGE}:${env.BUILD_NUMBER}|g' jenkins-app1/deployment.yaml"
                        sh '''
                        git config user.email "jenkins@local.com"
                        git config user.name "Jenkins CI"
                        git add jenkins-app1/deployment.yaml
                        git commit -m "Automated deployment: updated image tag to build ${BUILD_NUMBER} [skip ci]"
                        '''
                      withCredentials([usernamePassword(credentialsId: 'github-creds', passwordVariable: 'GIT_PASSWORD', usernameVariable: 'GIT_USERNAME')]) {
    sh '''
    # 1. יצירת URL עם משתני סביבה בצורה בטוחה
    REMOTE_URL="https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com/eli0504167101/devops_course.git"
    
    # 2. הוספת Remote זמני
    git remote add push-repo "${REMOTE_URL}" || git remote set-url push-repo "${REMOTE_URL}"
    
    # 3. ביצוע ה-push ל-Remote הזה
    git push push-repo HEAD:master
    
    # 4. ניקוי ה-Remote כדי לא להשאיר סיסמאות בקונפיגורציה
    git remote remove push-repo
    '''
}
                    }
                }
            }
        }
    }
}
